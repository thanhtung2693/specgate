# Root Compose overrides.
# Copy to .env and uncomment any line you want to change.

# ── Host port overrides ──────────────────────────────────────────────────────
# Only affect host-side port bindings; container-to-container networking is
# unaffected. DOC_REGISTRY_PORT and AGENTS_PORT are baked into the UI image
# at build time — if you change them, rebuild: docker compose up --build ui

# DOC_REGISTRY_PORT=8080
# AGENTS_PORT=2024
# UI_PORT=3000
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MINIO_ROOT_USER=specgate-minio
# MINIO_ROOT_PASSWORD=specgate-minio-dev-only

# ── External service overrides for Docker Compose ───────────────────────────
# Leave unset to use the bundled local Compose services.
# POSTGRES_DSN=postgres://docreg:docreg@postgres:5432/docreg?sslmode=disable
# DATABASE_URI=postgres://docreg:docreg@postgres:5432/langgraph?sslmode=disable
# QUEUE_DRIVER=sync
# REDIS_URL=
# REDIS_URI=

# Optional bundled helper services. Default local setup does not start Redis or
# MinIO. Enable one or both profiles only when the matching driver needs them:
#   COMPOSE_PROFILES=redis
#   COMPOSE_PROFILES=s3
#   COMPOSE_PROFILES=redis,s3
# COMPOSE_PROFILES=
