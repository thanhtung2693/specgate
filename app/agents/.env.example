# Agents local env.
# Copy to .env when running the agents service outside docker compose.

# Doc Registry REST API. host.docker.internal works for `langgraph up` containers;
# native runs fall back to 127.0.0.1 when that hostname is unavailable.
DOC_REGISTRY_BASE_URL=http://host.docker.internal:8080

# Doc Registry MCP stream used by governance tools. Set DOC_REGISTRY_MCP_ENABLED=0
# to skip loading these tools.
MCP_SERVER_URL=http://host.docker.internal:8080/mcp/stream
# DOC_REGISTRY_MCP_ENABLED=0

# LangSmith tracing. Required by LangGraph Self-Hosted Lite; optional for native dev.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=specgate-governance

# Optional: LangGraph self-hosted storage for `langgraph up`.
# DATABASE_URI=postgres://docreg:docreg@host.docker.internal:5432/langgraph?sslmode=disable
# REDIS_URI=redis://host.docker.internal:6379/1

# Optional: override the support model used by governance-ops chat.
# GOVERNANCE_OPS_MODEL_PROVIDER=openai
# GOVERNANCE_OPS_MODEL=gpt-5.4-mini
# GOVERNANCE_OPS_API_KEY=
# GOVERNANCE_OPS_THINKING_LEVEL=low

# Optional: error monitoring.
# SENTRY_DSN=
