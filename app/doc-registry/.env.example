# Doc Registry local env.
# Copy to .env. `make run` / `make dev` auto-generate SETTINGS_ENCRYPTION_KEY
# when this file is copied with an empty value.

# Required: 32-byte hex AES key for encrypted settings.
SETTINGS_ENCRYPTION_KEY=

# Required: Doc Registry is Postgres-only.
POSTGRES_DSN=

# Local agents service. Leave empty to disable agent-backed governance operations.
AGENTS_BASE_URL=http://localhost:2024

# Local UI origin used in generated links. Leave APP_BASE_URL empty in a
# side-by-side local stack to derive http://localhost:<UI_PORT>.
APP_BASE_URL=http://localhost:3000
# UI_PORT=3000

# Optional: days before a failing delivery review appears as delivery_stale.
# DELIVERY_SLA_DAYS=7

# Optional: opt-in artifact retention sweeper (spec §9). Deletes superseded
# artifacts past 90 days and needs_changes past 30 days; never approved/draft,
# and skips artifacts referenced by a feature or change request.
# ARTIFACT_RETENTION_SWEEP_ENABLED=true
# ARTIFACT_RETENTION_SWEEP_INTERVAL_HOURS=24

# Optional: async queue for inbound webhooks AND Knowledge ingestion. Requires
# Redis. Default "sync" runs both inline in-request (no Redis). WEBHOOK_QUEUE_MAX_RETRY
# caps retries for the shared async worker.
# QUEUE_DRIVER=redis
# REDIS_URL=redis://localhost:6379/2

# Optional: S3/MinIO blob storage. Default is local filesystem under /data/blobs.
# STORAGE_DRIVER=s3
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=specgate-minio
# S3_SECRET_KEY=specgate-minio-dev-only
# S3_BUCKET=doc-registry

# Optional: knowledge vector search. Default is disabled.
# KNOWLEDGE_DRIVER=pgvector

# Optional: provider OAuth apps. Selected resources own managed webhook credentials.
# OAUTH_PUBLIC_CALLBACK_BASE_URL=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITLAB_OAUTH_CLIENT_ID=
# GITLAB_OAUTH_CLIENT_SECRET=
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=

# Optional: error monitoring.
# SENTRY_DSN=
