# Doc Registry local env.
# Copy to .env. `make run` / `make dev` auto-generate SETTINGS_ENCRYPTION_KEY
# when this file is copied with an empty value.

# Required: 32-byte hex AES key for encrypted settings.
SETTINGS_ENCRYPTION_KEY=

# Required: Doc Registry is Postgres-only.
DATABASE_DRIVER=postgres
POSTGRES_DSN=

# Local agents service. Leave empty to disable agent-backed MCP tools.
AGENTS_BASE_URL=http://localhost:2024

# Local UI origin used in generated work-item links.
APP_BASE_URL=http://localhost:3000

# Optional: pin the MCP bearer token. If unset, Doc Registry stores and rotates
# mcp.api_key in encrypted settings.
# MCP_API_KEY=

# Optional: async webhook queue. Requires Redis.
# QUEUE_DRIVER=redis
# REDIS_URL=redis://localhost:6379/2

# Optional: S3/MinIO blob storage. Default is local filesystem under /data/blobs.
# STORAGE_DRIVER=s3
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=specgate-minio
# S3_SECRET_KEY=specgate-minio-dev-only
# S3_BUCKET=doc-registry

# Optional: knowledge vector search. Default is disabled.
# KNOWLEDGE_DRIVER=pgvector

# Optional: provider OAuth apps and Linear webhook fallback.
# OAUTH_PUBLIC_CALLBACK_BASE_URL=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITLAB_OAUTH_CLIENT_ID=
# GITLAB_OAUTH_CLIENT_SECRET=
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=
# LINEAR_WEBHOOK_SECRET=

# Optional: error monitoring.
# SENTRY_DSN=
