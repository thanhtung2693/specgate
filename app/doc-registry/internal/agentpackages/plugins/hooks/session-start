#!/usr/bin/env bash
# Inject a short router hint. The focused skill stays the source of truth and is
# loaded only for an explicit SpecGate task.

set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROUTER="${SCRIPT_DIR}/../skills/specgate/SKILL.md"
if [ ! -f "$ROUTER" ]; then
  exit 0
fi

CONTENT='<EXTREMELY_IMPORTANT>
SpecGate skills are installed. When the user explicitly mentions SpecGate, load `specgate`; for lifecycle work, load exactly one phase before a write. Read-only concept and troubleshooting questions stay in the root skill. Do not apply the SpecGate lifecycle to generic specifications or work that is not tied to SpecGate.
</EXTREMELY_IMPORTANT>'

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

ESCAPED="$(escape_for_json "$CONTENT")"
PLATFORM="${1:-codex}"

if [ "$PLATFORM" = "claude" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$ESCAPED"
else
  printf '{"additionalContext":"%s"}\n' "$ESCAPED"
fi
