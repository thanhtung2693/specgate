# Browser-facing URLs. Keep these same-origin in Vite dev so browser CORS does
# not depend on each backend server.
VITE_DOC_REGISTRY_URL=/api/doc-registry
VITE_LANGGRAPH_API_URL=/api/agents

# Vite proxy targets. Override these when your compose stack uses non-default
# host ports. Set SPECGATE_PROXY_TARGET to use the appliance gateway instead;
# the raw-service targets below are ignored in that mode.
SPECGATE_PROXY_TARGET=http://127.0.0.1:3000
DOC_REGISTRY_PROXY_TARGET=http://127.0.0.1:8080
LANGGRAPH_PROXY_TARGET=http://127.0.0.1:2024
