# agents environment — copy to agents.env.
#
# Optional tracing key. Leave blank for local alpha evaluation.
LANGSMITH_API_KEY=

# Optional governance chat model. The chat panel in the web UI answers
# questions (gate failures, blockers, artifact context) only when this key is
# set; without it the panel shows setup instructions and every other SpecGate
# workflow keeps working. This is separate from the server-side ops model
# configured in Settings -> Models.
GOVERNANCE_OPS_API_KEY=
# GOVERNANCE_OPS_MODEL=gpt-5.4-mini
# GOVERNANCE_OPS_MODEL_PROVIDER=openai
