# syntax=docker/dockerfile:1.7

# SpecGate local appliance: one image containing the existing UI, Doc Registry,
# Agents runtime, and PostgreSQL/pgvector. Only nginx is reachable from outside.

FROM node:26-alpine AS ui-build
WORKDIR /src/ui
COPY app/ui/package.json app/ui/package-lock.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci --no-audit --no-fund
COPY app/ui/ ./
ARG BUILD_MODE=production
ARG VITE_DOC_REGISTRY_URL=/api/doc-registry
ARG VITE_LANGGRAPH_API_URL=/api/agents
ENV VITE_DOC_REGISTRY_URL=$VITE_DOC_REGISTRY_URL \
    VITE_LANGGRAPH_API_URL=$VITE_LANGGRAPH_API_URL
RUN npm run build -- --mode "${BUILD_MODE}"

FROM golang:1.26.5-bookworm AS registry-build
WORKDIR /src
COPY app/doc-registry/go.mod app/doc-registry/go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod go mod download
COPY app/doc-registry/ ./
COPY plugins /src/plugins
RUN SPECGATE_PLUGIN_SOURCE=/src/plugins \
    SPECGATE_EMBEDDED_PLUGIN_DEST=/src/internal/agentpackages/plugins \
    sh scripts/sync-embedded-plugins.sh
ARG VERSION=dev
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 go build \
      -ldflags "-X github.com/specgate/doc-registry/internal/buildinfo.Version=${VERSION}" \
      -o /out/doc-registry ./cmd/doc-registry \
    && GOBIN=/out go install github.com/tianon/gosu@1.19

# Build the Python environment on the same supported Trixie base as the
# appliance runtime so copied interpreter binaries and wheels stay aligned.
# LangChain's Pydantic v1 compatibility layer is not supported on Python 3.14.
FROM python:3.13-slim-trixie AS agents-build
COPY --from=ghcr.io/astral-sh/uv:0.11.15 /uv /usr/local/bin/uv
WORKDIR /opt/specgate/agents
# Keep the expensive, lockfile-resolved dependency layer independent of agent
# source edits. The second sync below only installs the local project when its
# source changes.
COPY app/agents/pyproject.toml app/agents/uv.lock app/agents/README.md ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project
COPY app/agents/ ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev

FROM pgvector/pgvector:0.8.5-pg18-trixie
ARG VERSION=dev
ARG COMMIT=unknown
ARG BUILD_DATE=unknown
LABEL org.opencontainers.image.title="SpecGate Local Appliance" \
      org.opencontainers.image.source="https://github.com/thanhtung2693/specgate" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${COMMIT}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.specgate.managed="true" \
      org.specgate.component="appliance"

ENV SPECGATE_VERSION=${VERSION}

RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
      ca-certificates curl libsqlite3-0 nginx xz-utils \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --system --uid 10001 --home-dir /nonexistent --shell /usr/sbin/nologin specgate \
    && useradd --system --uid 10002 --home-dir /nonexistent --shell /usr/sbin/nologin agents

COPY --from=agents-build /usr/local/ /usr/local/
COPY --from=agents-build /opt/specgate/agents /opt/specgate/agents
COPY --from=registry-build /out/doc-registry /usr/local/bin/doc-registry
COPY --from=registry-build /out/gosu /usr/local/bin/gosu
COPY --from=ui-build /src/ui/dist /usr/share/nginx/html

COPY docker/local/nginx.conf /etc/specgate/nginx.conf
COPY docker/local/entrypoint.sh /usr/local/bin/specgate-entrypoint
COPY docker/local/healthcheck.sh /usr/local/bin/specgate-healthcheck
COPY docker/local/backup.sh /usr/local/bin/specgate-backup
COPY docker/local/service-finish.sh /usr/local/bin/specgate-service-finish
COPY docker/local/health_server.py /usr/local/lib/specgate/health_server.py
COPY docker/local/s6-rc.d/ /etc/s6-overlay/s6-rc.d/

ARG TARGETARCH
ARG S6_OVERLAY_VERSION=3.2.2.0
RUN set -eux; \
    case "${TARGETARCH}" in \
      amd64) s6_arch=x86_64 ;; \
      arm64) s6_arch=aarch64 ;; \
      *) echo "unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    base="https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}"; \
    for archive in s6-overlay-noarch.tar.xz "s6-overlay-${s6_arch}.tar.xz"; do \
      curl -fsSLO "${base}/${archive}"; \
      curl -fsSLO "${base}/${archive}.sha256"; \
      sha256sum -c "${archive}.sha256"; \
      tar -C / -Jxpf "${archive}"; \
      rm -f "${archive}" "${archive}.sha256"; \
    done

RUN chmod 0755 \
      /usr/local/bin/specgate-entrypoint \
      /usr/local/bin/specgate-healthcheck \
      /usr/local/bin/specgate-backup \
      /usr/local/bin/specgate-service-finish \
      /etc/s6-overlay/s6-rc.d/*/run \
      /etc/s6-overlay/s6-rc.d/*/finish \
    && mkdir -p /data/postgres /data/registry /data/diagnostics /run/specgate /tmp/specgate-agents /tmp/specgate-nginx /opt/specgate/agents/.langgraph_api \
    && chown postgres:postgres /data/postgres \
    && chown specgate:specgate /data/registry /data/diagnostics /run/specgate /tmp/specgate-nginx \
    && chown agents:agents /tmp/specgate-agents /opt/specgate/agents/.langgraph_api

ENV PGDATA=/data/postgres \
    POSTGRES_USER=docreg \
    POSTGRES_PASSWORD=docreg \
    POSTGRES_DB=docreg \
    HTTP_ADDR=127.0.0.1:8080 \
    POSTGRES_DSN=postgres://docreg:docreg@127.0.0.1:5432/docreg?sslmode=disable \
    AGENTS_BASE_URL=http://127.0.0.1:2024 \
    DOC_REGISTRY_BASE_URL=http://127.0.0.1:8080 \
    STORAGE_DRIVER=local \
    BLOB_DATA_ROOT=/data/registry/blobs \
    KNOWLEDGE_DRIVER=pgvector \
    QUEUE_DRIVER=sync \
    APP_BASE_URL=http://localhost:3000 \
    HOME=/tmp/specgate-agents \
    PATH=/opt/specgate/agents/.venv/bin:$PATH

VOLUME ["/data"]
EXPOSE 3000
HEALTHCHECK --interval=10s --timeout=5s --start-period=45s --retries=6 \
  CMD ["/usr/local/bin/specgate-healthcheck"]
ENTRYPOINT ["/usr/local/bin/specgate-entrypoint"]
